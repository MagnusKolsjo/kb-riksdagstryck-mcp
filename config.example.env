# =============================================================================
# config.example.env — Mall för konfiguration
# Kopiera den här filen till .env och fyll i dina egna värden.
# .env checkas ALDRIG in i Git (se .gitignore).
# =============================================================================

# ── Databasanslutning ──────────────────────────────────────────────────────────
# En enda DATABASE_URL ersätter separata PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD.
# docker-compose.yml använder POSTGRES_USER, POSTGRES_PASSWORD och POSTGRES_DB
# ur .env och skapar användaren automatiskt vid första start.
#
# PostgreSQL (rekommenderas — krävs för vektorsökning)
DATABASE_URL=postgresql://mitt_db_anvandare:byt_till_eget_starkt_losenord@localhost:5432/riksdag

# SQLite (fallback utan vektorsökning — begränsad funktionalitet)
# DATABASE_URL=sqlite:///kb_riksdagstryck_cache.db

# ── Filsökvägar ────────────────────────────────────────────────────────────────
# Sökväg där nedladdade XML-filer lagras lokalt
XML_RAW_DIR=./xml_raw

# Sökväg där PDF-filer lagras (de 16 PDF-only volymerna)
PDF_RAW_DIR=./pdf_raw

# ── Embeddingmodell ────────────────────────────────────────────────────────────
# KBLab/sentence-bert-swedish-cased är tränad specifikt för semantisk likhet
# (knowledge distillation från all-mpnet-base-v2) och ger bättre sökresultat
# än den generella KBLab/bert-base-swedish-cased. Körs lokalt, ingen API-nyckel.
EMBEDDING_MODEL=KBLab/sentence-bert-swedish-cased

# ── Nedladdning ────────────────────────────────────────────────────────────────
# Antal sekunder paus mellan nedladdningar (var snäll mot KB:s server)
DOWNLOAD_DELAY=0.5

# Max antal nätverksfel innan nedladdning avbryts
MAX_ERRORS=10

# ── Transport och autentisering ────────────────────────────────────────────────
# Transport: "stdio" (lokal, standardläge) eller "http" (hostad driftsättning).
MCP_TRANSPORT=stdio

# Värdadress och port för HTTP-transporten (används bara om MCP_TRANSPORT=http).
MCP_HOST=127.0.0.1
MCP_PORT=8000

# API-nyckel för HTTP-transporten.
# Generera: python3 -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=

# ── Query-expansion (valfritt) ─────────────────────────────────────────────────
# Aktivera för att låta ett LLM utöka söktermen med historiska stavningsvarianter
# och latinska ekvivalenter innan databasfrågan körs.
#
# Stöder alla OpenAI-kompatibla endpoints:
#   Claude:    QUERY_EXPANSION_BASE_URL=https://api.anthropic.com/v1
#   OpenAI:    lämna QUERY_EXPANSION_BASE_URL tomt (standard)
#   Ollama:    QUERY_EXPANSION_BASE_URL=http://localhost:11434/v1
#   LM Studio: QUERY_EXPANSION_BASE_URL=http://localhost:1234/v1
#
# Promptfilen i prompts/expansion_prompt.txt kan redigeras för att anpassa
# expansionen. Den kan också användas som grund för en MCP-skill — se README.
QUERY_EXPANSION_ENABLED=false
QUERY_EXPANSION_BASE_URL=
QUERY_EXPANSION_API_KEY=
QUERY_EXPANSION_MODEL=
# QUERY_EXPANSION_PROMPT_FILE=./prompts/expansion_prompt.txt  # standard, ändra vid behov
