# =============================================================================
# config.example.env — Mall för konfiguration
# Kopiera den här filen till .env och fyll i dina egna värden.
# .env checkas ALDRIG in i Git (se .gitignore).
# =============================================================================

# PostgreSQL-anslutning
# Välj eget användarnamn och lösenord — ändra dessa innan du startar!
# docker-compose.yml läser samma variabler och skapar användaren automatiskt.
PGHOST=localhost
PGPORT=5432
PGDATABASE=riksdagstryck
PGUSER=mitt_db_anvandare
PGPASSWORD=byt_till_eget_starkt_losenord

# Sökväg där nedladdade XML-filer lagras lokalt
XML_RAW_DIR=./xml_raw

# Sökväg där PDF-filer lagras (de 16 PDF-only volymerna)
PDF_RAW_DIR=./pdf_raw

# Embeddingmodell för semantisk sökning (körs lokalt via sentence-transformers, ingen API-nyckel krävs)
# KBLab/sentence-bert-swedish-cased är tränad specifikt för semantisk likhet (knowledge distillation
# från all-mpnet-base-v2) och ger bättre sökresultat än den generella KBLab/bert-base-swedish-cased.
EMBEDDING_MODEL=KBLab/sentence-bert-swedish-cased

# Antal sekunder paus mellan nedladdningar (var snäll mot KB:s server)
DOWNLOAD_DELAY=0.5

# Max antal nätverksfel innan nedladdning avbryts
MAX_ERRORS=10
